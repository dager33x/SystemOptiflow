## SystemOptiflow environment variables
##
## Copy this file to `.env` and fill in your values:
##   Copy-Item .env.example .env
##
## IMPORTANT: Do NOT commit `.env` (secrets).

# Supabase (optional)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key
# Service role key — used server-side for Storage uploads (bypasses RLS).
# Get from: Supabase Dashboard → Project Settings → API → service_role key
# NEVER expose this key to the browser or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (optional)
# Used by utils/email_service.py
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password

# Web server
SESSION_SECRET=change-me-before-production
HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=https://optiflow.example.com
DEMO_USERNAME=admin
DEMO_PASSWORD=admin123
DEMO_ROLE=admin

# Optional Supabase Storage bucket for evidence images
SUPABASE_EVIDENCE_BUCKET=evidence

# Public desktop releases page
GITHUB_RELEASES_OWNER=dager33x
GITHUB_RELEASES_REPO=SystemOptiflow
GITHUB_TOKEN=
GITHUB_RELEASES_CACHE_TTL=300
GITHUB_RELEASES_TIMEOUT_SECONDS=10

# Camera sources (RTSP / USB)
# Options per lane:
#   Simulated                        - built-in traffic simulator (default)
#   Camera 0 / Camera 1 / ...        - local USB webcam by index
#   rtsp://192.168.1.100:554/stream1 - IP camera or DroidCam over RTSP
#   http://192.168.1.100:8080/video  - Android IP Webcam app (MJPEG)
#
# On the VPS with MediaMTX, phones push to port 8554 and FastAPI reads from
# the internal Docker hostname "mediamtx":
# CAMERA_SOURCE_NORTH=rtsp://mediamtx:8554/north
# CAMERA_SOURCE_SOUTH=rtsp://mediamtx:8554/south
# CAMERA_SOURCE_EAST=rtsp://mediamtx:8554/east
# CAMERA_SOURCE_WEST=rtsp://mediamtx:8554/west

# RTSP / MediaMTX
# Format in a phone RTSP app:
# rtsp://publisher:<password>@<vps-ip>:8554/north
RTSP_PUBLISH_PASSWORD=changeme

# DigitalOcean / DuckDNS / TLS (VPS deploy only)
DOMAIN=optiflow.duckdns.org
DUCKDNS_TOKEN=your-duckdns-token
CERTBOT_EMAIL=your@email.com

# WebRTC TURN relay (required for phone streaming over cellular)
# VPS_PUBLIC_IP must be the server's actual public IP (not the DuckDNS domain)
# vps_setup.sh installs coturn automatically using TURN_USERNAME and TURN_PASSWORD
VPS_PUBLIC_IP=your-vps-public-ip
TURN_USERNAME=optiflow
TURN_PASSWORD=changeme

# Optional runtime tuning
# RTSP_TRANSPORT=tcp
# AI_THROTTLE_SECONDS=0.2
# ENABLE_PERFORMANCE_TIMING=false
# PERFORMANCE_LOG_MIN_MS=0

# Optional remote YOLO inference (Modal)
# YOLO_REMOTE_ENABLED=false
# YOLO_REMOTE_LANES=all
# YOLO_REMOTE_INFERENCE_URL=https://your-workspace--optiflow-yolo-inference-detect.modal.run
# YOLO_REMOTE_INFERENCE_TOKEN=replace-with-secret-token
# YOLO_REMOTE_TIMEOUT_SECONDS=2.0
# YOLO_REMOTE_MIN_INTERVAL_SECONDS=0.45
# YOLO_REMOTE_JPEG_QUALITY=70
# YOLO_REMOTE_MAX_UPLOAD_WIDTH=640
# YOLO_REMOTE_MAX_UPLOAD_HEIGHT=480

# Optional Modal worker tuning
# YOLO_INFERENCE_IMAGE_SIZE=416
# YOLO_INFERENCE_DEVICE=0
# YOLO_CONFIDENCE_THRESHOLD=0.25
