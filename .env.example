## SystemOptiflow environment variables
##
## Copy this file to `.env` and fill in your values:
##   Copy-Item .env.example .env
##
## IMPORTANT: Do NOT commit `.env` (secrets).

# Supabase (optional)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# Email (optional)
# Used by utils/email_service.py
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password

# Web server
SESSION_SECRET=change-me-before-production
HOST=0.0.0.0
PORT=8000
DEMO_USERNAME=admin
DEMO_PASSWORD=admin123
DEMO_ROLE=admin

# Optional Supabase Storage bucket for evidence images
SUPABASE_EVIDENCE_BUCKET=evidence

# Camera sources (RTSP / USB)
# Options per lane:
#   Simulated                        - built-in traffic simulator (default)
#   Camera 0 / Camera 1 / ...        - local USB webcam by index
#   rtsp://192.168.1.100:554/stream1 - IP camera or DroidCam over RTSP
#   http://192.168.1.100:8080/video  - Android IP Webcam app (MJPEG)
#
# On the VPS with MediaMTX, phones push to port 8554 and FastAPI reads from
# the internal Docker hostname "mediamtx":
# CAMERA_SOURCE_NORTH=rtsp://mediamtx:8554/north
# CAMERA_SOURCE_SOUTH=rtsp://mediamtx:8554/south
# CAMERA_SOURCE_EAST=rtsp://mediamtx:8554/east
# CAMERA_SOURCE_WEST=rtsp://mediamtx:8554/west

# RTSP / MediaMTX
# Format in a phone RTSP app:
# rtsp://publisher:<password>@<vps-ip>:8554/north
RTSP_PUBLISH_PASSWORD=changeme

# DigitalOcean / DuckDNS / TLS (VPS deploy only)
DOMAIN=optiflow.duckdns.org
DUCKDNS_TOKEN=your-duckdns-token
CERTBOT_EMAIL=your@email.com

# Optional runtime tuning
# RTSP_TRANSPORT=tcp
# AI_THROTTLE_SECONDS=0.2
